# Copie para .env e ajuste. Nunca commitar .env com segredos reais.
#
# PRODUCAO (obrigatorio):
#   NODE_ENV=production
#   JWT_SECRET=<use openssl rand -base64 48 ou similar>
#   CORS_ORIGIN=https://seu-app.pages.dev
#   TRUST_PROXY=1   (API atras da Cloudflare ou outro proxy)

NODE_ENV=development
PORT=3001

# Banco MySQL (atual)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=kingstar_io

# Auth — em produção use segredo longo e aleatório
JWT_SECRET=troque_em_producao_use_openssl_rand

# CORS — origens permitidas separadas por vírgula (obrigatório em produção)
# Ex.: https://seu-app.pages.dev,https://www.seudominio.com
CORS_ORIGIN=http://localhost:5173

# Rate limit
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# Atrás de Cloudflare ou proxy reverso (IP real + limite por cliente)
TRUST_PROXY=0

# Futuro: migração MongoDB (ver doc/plano-migracao-mongodb.md)
# DB_PROVIDER=mysql
# MONGODB_URI=mongodb+srv://user:pass@cluster/db?retryWrites=true&w=majority
